{
  "tokenCallbacks": [
    {
      "issuerId": "connect",
      "requestMappings": [
        {
          "requestParam": "scope",
          "match": "ServiceDomainPlaceholderServiceRestApi",
          "claims": {
            "scope": [ "ServiceDomainPlaceholderServiceRestApi" ],
            "aud": [ "${clientId}" ],
            "client_id": "${clientId}"
          }
        }
      ]
    }
  ]
